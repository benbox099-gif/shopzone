            50% { opacity: 0.7; transform: translateY(-50%) scale(1.2); }
        }
    </style>

    <script>
        // Hide loading screen when page is fully loaded
        window.addEventListener('load', () => {
            setTimeout(() => {
                const loadingScreen = document.getElementById('loadingScreen');
