        // Emergency disable function
        function disableMaintenanceEmergency() {
            if (confirm('האם אתה בטוח שאתה רוצה לכבות את מצב התחזוקה?')) {
                localStorage.setItem('maintenanceMode', 'false');
                localStorage.removeItem('maintenanceText');
                location.reload();
            }
        }
    </script>

    <script>
        // Check maintenance mode on page load
        (function() {
            const maintenanceModeValue = localStorage.getItem('maintenanceMode');
            console.log('Maintenance mode value:', maintenanceModeValue);
            
            // Only show maintenance if explicitly set to 'true'
            // If null, undefined, 'false', or anything else - don't show
            const maintenanceMode = maintenanceModeValue === 'true';
            console.log('Maintenance mode enabled:', maintenanceMode);
            
            if (maintenanceMode) {
                const overlay = document.getElementById('maintenanceOverlay');
                const message = localStorage.getItem('maintenanceText') || 'האתר בתחזוקה זמנית. נחזור בקרוב!';
                const messageEl = document.getElementById('maintenanceText');
                if (messageEl) messageEl.textContent = message;
                if (overlay) {
                    overlay.style.display = 'flex';
                    document.body.style.overflow = 'hidden';
                }
                console.log('Maintenance mode activated');
            } else {
                // Make sure overlay is hidden
                const overlay = document.getElementById('maintenanceOverlay');
                if (overlay) {
                    overlay.style.display = 'none';
                }
                document.body.style.overflow = 'auto';
                console.log('Maintenance mode is OFF');
            }
        })();
