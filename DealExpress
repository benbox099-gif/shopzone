        // Add click handlers to all product cards
        function addProductCardClickHandlers() {
            // First, fix trust badges
            document.querySelectorAll('.trust-badge').forEach(badge => {
                const text = badge.textContent.trim();
                if (text.includes('החזר מובטח') || text.includes('Guaranteed')) {
                    badge.innerHTML = '🛡️ הגנת קונה';
                }
                if (text.includes('מאומת') || text.includes('Verified')) {
                    badge.innerHTML = '✓ מאומת';
                }
            });
            
            // Then add click handlers to cards
            const cards = document.querySelectorAll('.product-card, .best-seller-card');
            
            cards.forEach(card => {
                // Skip if already has handler
                if (card.dataset.hasClickHandler) return;
                card.dataset.hasClickHandler = 'true';
                
                card.style.cursor = 'pointer';
                
                // Get product ID from multiple sources
                let productId = null;
                
                // 1. Try data-product-id attribute
                if (card.dataset.productId) {
                    productId = parseInt(card.dataset.productId);
                }
                
                // 2. Try save button
                if (!productId) {
                    const saveBtn = card.querySelector('.save-btn');
                    if (saveBtn) {
                        const onclickAttr = saveBtn.getAttribute('onclick');
                        if (onclickAttr) {
                            const match = onclickAttr.match(/toggleSave\(event, (\d+)\)/);
                            if (match) {
                                productId = parseInt(match[1]);
                            }
                        }
                    }
                }
                
                // 3. Try buy button onclick with trackView
                if (!productId) {
                    const buyLink = card.querySelector('a[onclick*="trackView"]');
                    if (buyLink) {
                        const onclickAttr = buyLink.getAttribute('onclick');
                        if (onclickAttr) {
                            const match = onclickAttr.match(/trackView\((\d+)\)/);
                            if (match) {
                                productId = parseInt(match[1]);
                            }
                        }
                    }
                }
                
                // Add click handler to card
                card.addEventListener('click', function(e) {
