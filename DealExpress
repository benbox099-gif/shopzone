                if (currentCategory === 'all') {
                    displayProducts(products);
                } else {
                    filterCategory(currentCategory);
                }
            }

            // Rebuild slider from localStorage
            rebuildSlider();

            // Load best sellers
            const savedBestSellers = JSON.parse(localStorage.getItem('bestSellers') || '[]');
            if (savedBestSellers.length > 0) {
                updateBestSellers(savedBestSellers);
            }
        }

        // Rebuild entire slider from localStorage
        function rebuildSlider() {
            const savedSlides = JSON.parse(localStorage.getItem('sliderSlides') || '{}');
            
            // If no saved slides, keep default
            if (Object.keys(savedSlides).length === 0) {
                console.log('No saved slides, keeping default');
                return;
            }

            console.log('Rebuilding slider with saved data:', savedSlides);

            // Update each slide
            for (let i = 1; i <= 3; i++) {
                if (savedSlides[i]) {
                    const product = products.find(p => p.id == savedSlides[i].productId);
                    if (product) {
                        const slide = document.querySelector(`.slide-${i}`);
                        if (slide) {
                            console.log(`Updating slide ${i} with product:`, product.name);
                            
                            // Update title (always update, even if empty)
                            const titleEl = slide.querySelector('.slide-text h1');
                            if (titleEl) {
                                titleEl.textContent = savedSlides[i].title || (product.emoji + ' מומלץ!');
                                console.log(`Title updated to: ${titleEl.textContent}`);
                            }

                            // Update description (always update, even if empty)
                            const descEl = slide.querySelector('.slide-text p');
                            if (descEl) {
                                descEl.textContent = savedSlides[i].description || product.name;
                                console.log(`Description updated to: ${descEl.textContent}`);
                            }

                            // Update product emoji
                            const emojiEl = slide.querySelector('.slide-product-image');
                            if (emojiEl) {
                                emojiEl.textContent = product.emoji;
                                console.log(`Emoji updated to: ${product.emoji}`);
                            }

                            // Update product name
                            const nameEl = slide.querySelector('.slide-product-name');
                            if (nameEl) {
                                nameEl.textContent = product.name;
                            }

                            // Update price
                            const priceEl = slide.querySelector('.slide-price');
                            if (priceEl) {
                                priceEl.textContent = '₪' + product.price;
                            }

                            // Update old price
                            const oldPriceEl = slide.querySelector('.slide-old-price');
                            if (oldPriceEl) {
                                oldPriceEl.textContent = '₪' + product.oldPrice;
                            }

                            // Update discount
                            const discountEl = slide.querySelector('.slide-discount');
                            if (discountEl) {
                                discountEl.textContent = '-' + product.discount + '%';
                            }

                            // Update link
                            const linkEl = slide.querySelector('.banner-btn');
                            if (linkEl) {
                                linkEl.href = product.link;
                                console.log(`Link updated to: ${product.link}`);
                            }

                            console.log(`✅ Slide ${i} updated successfully`);
                        } else {
                            console.error(`❌ Slide ${i} element not found!`);
                        }
                    } else {
                        console.error(`❌ Product with ID ${savedSlides[i].productId} not found!`);
                    }
                }
            }

            console.log('✅ Slider rebuild completed');
        }

        // Update slider content dynamically (legacy - not used anymore)
        function updateSliderContent(slides) {
            // This function is no longer needed as we rebuild the entire slider
            console.log('updateSliderContent called but using rebuildSlider instead');
        }

        // Update best sellers section
        function updateBestSellers(bestSellerIds) {
            const bestSellersGrid = document.querySelector('.best-sellers-grid');
            if (bestSellersGrid && bestSellerIds.length > 0) {
                const selectedProducts = bestSellerIds.map(id => products.find(p => p.id == id)).filter(p => p);
                if (selectedProducts.length > 0) {
                    bestSellersGrid.innerHTML = selectedProducts.map(product => `
                        <div class="best-seller-card" onclick="openProductModal(${product.id})">
                            <div class="best-seller-badge">⭐ מומלץ</div>
                            <div class="product-image">${product.emoji}</div>
                            <div class="product-info">
                                <h3 class="product-name">${product.name}</h3>
                                <div class="product-rating">
                                    <span class="stars">${'⭐'.repeat(Math.floor(product.rating))}</span>
                                    <span class="rating-text">${product.rating} (${product.reviews.toLocaleString()} ביקורות)</span>
                                </div>
                                <div class="product-price-box">
                                    <span class="product-price">₪${product.price}*</span>
                                    <span class="product-old-price">₪${product.oldPrice}</span>
                                    <span class="product-discount">-${product.discount}%</span>
                                </div>
                                <div class="product-badges">
                                    <span class="badge">🛡️ הגנת קונה</span>
                                    <span class="badge">✓ מאומת</span>
                                    <span class="badge">📦 משלוח בינלאומי</span>
                                </div>
                                <button class="buy-now-btn" onclick="event.stopPropagation(); trackAnalytics('product_click', ${product.id}); sendWhatsAppNotification(${JSON.stringify(product).replace(/"/g, '&quot;')}); window.open('${product.link}', '_blank')">קנה עכשיו</button>
                            </div>
                        </div>
                    `).join('');
                }
            }
        }

        // Load dynamic content on page load
        window.addEventListener('DOMContentLoaded', function() {
            console.log('🌐 Page loaded from:', window.location.href);
            console.log('📂 Current path:', window.location.pathname);
            
            // Check for category parameter in URL
            const urlParams = new URLSearchParams(window.location.search);
            const categoryParam = urlParams.get('category');
            
            // Check if data came from admin panel via URL hash
            if (window.location.hash.includes('sliderData=')) {
                try {
                    const hashData = window.location.hash.split('sliderData=')[1];
                    const data = JSON.parse(decodeURIComponent(hashData));
                    
                    if (data.slides) {
                        localStorage.setItem('sliderSlides', JSON.stringify(data.slides));
                        console.log('✅ Slider data loaded from admin!');
                    }
                    if (data.bestSellers) {
                        localStorage.setItem('bestSellers', JSON.stringify(data.bestSellers));
                        console.log('✅ Best sellers loaded from admin!');
                    }
                    
                    // Remove hash and reload
                    window.location.hash = '';
                    window.location.reload();
                    return;
                } catch (e) {
                    console.error('Error loading data from hash:', e);
                }
            }
            
            console.log('🔍 Checking localStorage...');
            console.log('📦 sliderSlides:', localStorage.getItem('sliderSlides'));
            console.log('⭐ bestSellers:', localStorage.getItem('bestSellers'));
            
            loadDynamicContent();
            
            // Check for category parameter
            if (categoryParam) {
                console.log('🔍 Category parameter found:', categoryParam);
                // Hide banner, trust message, and best sellers for cleaner look
                document.getElementById('mainBanner').style.display = 'none';
                document.querySelector('.trust-message').style.display = 'none';
                document.querySelector('.best-sellers').style.display = 'none';
                
                // Filter products by category
                setTimeout(function() {
                    filterCategory(categoryParam);
                }, 300);
            }
            
            console.log('✅ Page initialization complete');
        });
    </script>
    
